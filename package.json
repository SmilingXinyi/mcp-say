{
    "name": "mcp-say",
    "version": "1.0.1",
    "description": "Provide professional 'say' command MCP services.",
    "type": "module",
    "license": "MIT",
    "author": "Xinyi <smilingxinyi@gmail.com>",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/SmilingXinyi/mcp-say.git"
    },
    "homepage": "https://github.com/SmilingXinyi/mcp-say#readme",
    "bugs": {
        "url": "https://github.com/SmilingXinyi/mcp-say/issues"
    },
    "keywords": [
        "mcp",
        "model-context-protocol",
        "macos",
        "tts",
        "text-to-speech",
        "say",
        "speech-synthesis",
        "cursor",
        "claude-code"
    ],
    "bin": {
        "mcp-say": "./build/index.js"
    },
    "files": [
        "build",
        "README.md",
        "LICENSE"
    ],
    "engines": {
        "node": ">=18"
    },
    "packageManager": "pnpm@10.30.1",
    "scripts": {
        "prepublishOnly": "pnpm build",
        "build": "tsc",
        "test": "tsx --test test/**/*.test.ts",
        "test:unit": "tsx --test test/unit/**/*.test.ts",
        "test:integration": "tsx --test test/integration/**/*.test.ts",
        "debug": "npx @modelcontextprotocol/inspector npx tsx src/index.ts",
        "bundle": "bun build ./src/index.ts --compile --outfile mcp-say",
        "build:bin": "bash bundle.sh",
        "format": "prettier --write .",
        "commit": "cz",
        "commitlint": "commitlint --edit",
        "lint-staged": "lint-staged",
        "prepare": "node .husky/install.mjs"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.29.0",
        "debug": "^4.4.3",
        "dotenv": "^17.4.2",
        "express": "^5.2.1",
        "zod": "^3.25.76"
    },
    "devDependencies": {
        "@commitlint/cli": "^21.2.0",
        "@commitlint/config-conventional": "^21.2.0",
        "@modelcontextprotocol/inspector": "^0.22.0",
        "@types/debug": "^4.1.13",
        "@types/express": "^5.0.6",
        "@types/node": "^26.1.0",
        "commitizen": "^4.3.2",
        "cz-conventional-changelog": "^3.3.0",
        "husky": "^9.1.7",
        "lint-staged": "^15.5.2",
        "prettier": "~3.5.3",
        "tsx": "^4.22.4",
        "typescript": "^6.0.3"
    },
    "config": {
        "commitizen": {
            "path": "cz-conventional-changelog"
        }
    }
}
